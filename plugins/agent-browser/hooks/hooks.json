{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/browser_memory.py context-from-env 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/browser_memory.py extract-session 2>/dev/null; python3 ${CLAUDE_PLUGIN_ROOT}/scripts/browser_memory.py maintain 2>/dev/null || true",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
